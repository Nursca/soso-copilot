# Anthropic API Key for AI research and signal generation
# Get yours at https://console.anthropic.com/
# Required for Claude 3.5 Sonnet to generate market briefs and chat
ANTHROPIC_API_KEY=sk-ant-api03-...

# SoSoValue API Key for live ETF flows and macro data
# Get yours at https://sosovalue.com/api
# Required to fetch institutional ETF flow data and macro calendars
SOSOVALUE_API_KEY=SOSO-...

# Reown (WalletConnect) Project ID for wallet integration
# Get yours at https://cloud.reown.com/
# Required for AppKit to enable wallet connection (MetaMask, etc.)
NEXT_PUBLIC_REOWN_PROJECT_ID=your_reown_project_id_here

# App URL for Reown metadata (use your deployed URL in production)
NEXT_PUBLIC_APP_URL=http://localhost:3000
